# CDEK API v2
# Sandbox: https://api.edu.cdek.ru/v2  |  Production: https://api.cdek.ru/v2
CDEK_API_URL=
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# SMTP — отправка отзывов на почту (nodemailer)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=your_password
REVIEW_EMAIL_TO=admin@smartcardio.ru

# Telegram — уведомления о вопросах с сайта
# Создать бота: https://t.me/BotFather → /newbot
# Узнать chat_id: написать боту и открыть https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAABBBCCC...
TELEGRAM_CHAT_ID=123456789

