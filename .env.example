# Порт сервера (по умолчанию 3000)
PORT=3000

# CDEK — основной API (запросы к ПВЗ, тарифам, заказам)
# Прокси:     https://lk.smartcardio.ru/cdek/v2
# Напрямую:   https://api.cdek.ru/v2
# Sandbox:    https://api.edu.cdek.ru/v2
CDEK_API_URL=https://lk.smartcardio.ru/cdek/v2

# CDEK — авторизация (OAuth, всегда прямо на СДЭК, не через прокси)
# Прямой:  https://api.cdek.ru/v2
# Sandbox: https://api.edu.cdek.ru/v2
CDEK_AUTH_URL=https://api.cdek.ru/v2

CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# SMTP — отправка отзывов на почту (nodemailer)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=your_password
REVIEW_EMAIL_TO=admin@smartcardio.ru

# Telegram — уведомления о вопросах с сайта
# Создать бота: https://t.me/BotFather → /newbot
# Узнать chat_id: написать боту и открыть https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAABBBCCC...
TELEGRAM_CHAT_ID=123456789

