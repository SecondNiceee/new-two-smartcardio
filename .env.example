# Порт сервера
PORT=3000

# Хост, на котором слушает сервер (по умолчанию 127.0.0.1)
# Укажите 0.0.0.0, чтобы принимать подключения со всех сетевых интерфейсов
HOST=127.0.0.1

# Базовый URL сайта — используется для SEO (canonical, Open Graph, sitemap, robots, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://smartcardio.ru

# CDEK
# Базовый URL прокси-сервера СДЭК (без /v2 на конце, но с /cdek)
# По умолчанию: https://lk.smartcardio.ru/cdek
CDEK_BASE_URL=https://lk.smartcardio.ru/cdek
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=

# SMTP — отправка отзывов на почту (nodemailer)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
# SMTP_SECURE=true     # true = всегда SSL, false = никогда. Если не задано — SSL включается автоматически при порте 465
# SMTP_USER=           # логин (опционально: если не задан — работает open relay без аутентификации)
# SMTP_PASS=           # пароль (опционально: если не задан — работает open relay без аутентификации)
# SMTP_FROM=           # адрес отправителя (опционально: если не задан — берётся SMTP_USER, иначе noreply@smartcardio.ru)
REVIEW_EMAIL_TO=admin@smartcardio.ru

# Telegram — уведомления о вопросах с сайта
# Создать бота: https://t.me/BotFather → /newbot
# Узнать chat_id: написать боту и открыть https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAABBBCCC...
TELEGRAM_CHAT_ID=123456789

